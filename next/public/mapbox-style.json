{
    "version": 8,
    "name": "TikTak Brand (legacy)",
    "sources": {
        "mapbox-streets": {
            "type": "vector",
            "url": "mapbox://mapbox.mapbox-streets-v8"
        }
    },
    "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
    "sprite": "mapbox://sprites/mapbox/dark-v11",
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {
                "background-color": "#120f1c"
            }
        },
        {
            "id": "landuse",
            "type": "fill",
            "source": "mapbox-streets",
            "source-layer": "landuse",
            "paint": {
                "fill-color": "#18142a"
            }
        },
        {
            "id": "landuse-residential",
            "type": "fill",
            "source": "mapbox-streets",
            "source-layer": "landuse",
            "filter": [
                "==",
                "class",
                "residential"
            ],
            "paint": {
                "fill-color": "#1a1630"
            }
        },
        {
            "id": "landuse-park",
            "type": "fill",
            "source": "mapbox-streets",
            "source-layer": "landuse",
            "filter": [
                "in",
                "class",
                "park",
                "grass",
                "pitch",
                "garden"
            ],
            "paint": {
                "fill-color": "#16243a",
                "fill-opacity": 0.8
            }
        },
        {
            "id": "landuse-industrial",
            "type": "fill",
            "source": "mapbox-streets",
            "source-layer": "landuse",
            "filter": [
                "==",
                "class",
                "industrial"
            ],
            "paint": {
                "fill-color": "#1c1530"
            }
        },
        {
            "id": "landuse-cemetery",
            "type": "fill",
            "source": "mapbox-streets",
            "source-layer": "landuse",
            "filter": [
                "==",
                "class",
                "cemetery"
            ],
            "paint": {
                "fill-color": "#171428"
            }
        },
        {
            "id": "water",
            "type": "fill",
            "source": "mapbox-streets",
            "source-layer": "water",
            "paint": {
                "fill-color": "#0d1f3c"
            }
        },
        {
            "id": "water-outline",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "water",
            "paint": {
                "line-color": "rgba(78, 255, 184, 0.13)",
                "line-width": 0.5
            }
        },
        {
            "id": "waterway",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "waterway",
            "paint": {
                "line-color": "rgba(78, 255, 184, 0.19)",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    8,
                    0.5,
                    14,
                    2
                ]
            }
        },
        {
            "id": "building",
            "type": "fill",
            "source": "mapbox-streets",
            "source-layer": "building",
            "paint": {
                "fill-color": "#1e1840",
                "fill-opacity": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    14,
                    0,
                    15,
                    0.85
                ]
            }
        },
        {
            "id": "building-outline",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "building",
            "paint": {
                "line-color": "rgba(91, 35, 255, 0.09)",
                "line-width": 0.5
            }
        },
        {
            "id": "road-path",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "road",
            "filter": [
                "in",
                "class",
                "path",
                "track"
            ],
            "paint": {
                "line-color": "#2a2050",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    12,
                    0.5,
                    18,
                    2
                ],
                "line-dasharray": [
                    3,
                    3
                ]
            }
        },
        {
            "id": "road-minor",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "road",
            "filter": [
                "in",
                "class",
                "street",
                "street_limited",
                "service",
                "tertiary"
            ],
            "paint": {
                "line-color": "#2d2260",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    10,
                    0.5,
                    16,
                    3
                ]
            }
        },
        {
            "id": "road-secondary",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "road",
            "filter": [
                "in",
                "class",
                "secondary",
                "primary"
            ],
            "paint": {
                "line-color": "#3d2e80",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    8,
                    1,
                    16,
                    6
                ]
            }
        },
        {
            "id": "road-major",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "road",
            "filter": [
                "in",
                "class",
                "trunk",
                "motorway"
            ],
            "paint": {
                "line-color": "#5B23FF",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    6,
                    1,
                    16,
                    8
                ],
                "line-opacity": 0.9
            }
        },
        {
            "id": "road-major-glow",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "road",
            "filter": [
                "in",
                "class",
                "trunk",
                "motorway"
            ],
            "paint": {
                "line-color": "#5B23FF",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    6,
                    4,
                    16,
                    20
                ],
                "line-opacity": 0.08,
                "line-blur": 6
            }
        },
        {
            "id": "boundary-country",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "admin",
            "filter": [
                "==",
                "admin_level",
                0
            ],
            "paint": {
                "line-color": "rgba(91, 35, 255, 0.38)",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    2,
                    0.5,
                    8,
                    2
                ],
                "line-dasharray": [
                    6,
                    3
                ]
            }
        },
        {
            "id": "boundary-region",
            "type": "line",
            "source": "mapbox-streets",
            "source-layer": "admin",
            "filter": [
                "==",
                "admin_level",
                1
            ],
            "paint": {
                "line-color": "rgba(91, 35, 255, 0.19)",
                "line-width": 1,
                "line-dasharray": [
                    4,
                    4
                ]
            }
        },
        {
            "id": "place-country",
            "type": "symbol",
            "source": "mapbox-streets",
            "source-layer": "place_label",
            "filter": [
                "==",
                "class",
                "country"
            ],
            "layout": {
                "text-field": [
                    "coalesce",
                    [
                        "get",
                        "name_en"
                    ],
                    [
                        "get",
                        "name"
                    ]
                ],
                "text-font": [
                    "Open Sans Bold",
                    "Arial Unicode MS Bold"
                ],
                "text-size": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    2,
                    8,
                    8,
                    18
                ],
                "text-transform": "uppercase",
                "text-letter-spacing": 0.15
            },
            "paint": {
                "text-color": "#e0d9ff",
                "text-halo-color": "#120f1c",
                "text-halo-width": 2
            }
        },
        {
            "id": "place-city",
            "type": "symbol",
            "source": "mapbox-streets",
            "source-layer": "place_label",
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "settlement"
                ],
                [
                    "in",
                    "type",
                    "city"
                ]
            ],
            "layout": {
                "text-field": [
                    "coalesce",
                    [
                        "get",
                        "name_en"
                    ],
                    [
                        "get",
                        "name"
                    ]
                ],
                "text-font": [
                    "Open Sans Bold",
                    "Arial Unicode MS Bold"
                ],
                "text-size": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    5,
                    11,
                    14,
                    22
                ]
            },
            "paint": {
                "text-color": "#e8e0ff",
                "text-halo-color": "#120f1c",
                "text-halo-width": 2
            }
        },
        {
            "id": "place-town",
            "type": "symbol",
            "source": "mapbox-streets",
            "source-layer": "place_label",
            "filter": [
                "all",
                [
                    "==",
                    "class",
                    "settlement"
                ],
                [
                    "in",
                    "type",
                    "town",
                    "village"
                ]
            ],
            "layout": {
                "text-field": [
                    "coalesce",
                    [
                        "get",
                        "name_en"
                    ],
                    [
                        "get",
                        "name"
                    ]
                ],
                "text-font": [
                    "Open Sans Regular",
                    "Arial Unicode MS Regular"
                ],
                "text-size": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    8,
                    9,
                    14,
                    14
                ]
            },
            "paint": {
                "text-color": "#c0b0f0",
                "text-halo-color": "#120f1c",
                "text-halo-width": 1.5
            }
        },
        {
            "id": "road-label-major",
            "type": "symbol",
            "source": "mapbox-streets",
            "source-layer": "road",
            "filter": [
                "in",
                "class",
                "primary",
                "secondary",
                "trunk",
                "motorway"
            ],
            "layout": {
                "text-field": [
                    "coalesce",
                    [
                        "get",
                        "name_en"
                    ],
                    [
                        "get",
                        "name"
                    ]
                ],
                "text-font": [
                    "Open Sans Semibold",
                    "Arial Unicode MS Regular"
                ],
                "text-size": 12,
                "symbol-placement": "line"
            },
            "paint": {
                "text-color": "#c0aaff",
                "text-halo-color": "#120f1c",
                "text-halo-width": 1.5
            }
        }
    ]
}